# ============================================================
# LEAD GENERATION SYSTEM — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── FREE LLM (choose one — both are completely free) ────────
# Option 1: Groq (recommended — very fast, Llama 3.3 70B)
#   Get free key: https://console.groq.com
GROQ_API_KEY=


# Option 2: Google Gemini Flash (1M free tokens/month)
#   Get free key: https://aistudio.google.com
# GEMINI_API_KEY=AIza...

# ── FREE DISCOVERY SOURCES ──────────────────────────────────
# These 3 sources need NO API key — scrape public pages directly:
#   Wellfound (AngelList) — startups hiring engineers
#   YC Directory          — funded startups (uses their public Algolia API)
#   BetaList              — new product launches by solo founders

# GitHub — free token at https://github.com/settings/tokens
# Grants 5,000 requests/hour (vs 60 anonymous)
GITHUB_TOKEN=

# Product Hunt — free developer token (optional)
#   Get token: https://www.producthunt.com/v2/oauth/applications
#   Leave blank to use the free scrape fallback
PRODUCTHUNT_TOKEN=

# ── FREE ENRICHMENT ─────────────────────────────────────────
# Hunter.io — 25 FREE lookups/month — https://hunter.io
# Leave blank to rely solely on SMTP email verification (also free)
HUNTER_API_KEY=

# ── GOOGLE (FREE) ───────────────────────────────────────────
# Follow: https://console.cloud.google.com
#   1. Create project → Enable Gmail API + Google Sheets API
#   2. Create OAuth 2.0 credentials → Download JSON
#   3. Run: python utils/gmail_auth.py  (generates refresh token)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GOOGLE_SHEETS_ID=

# ── OUTREACH CONFIG ─────────────────────────────────────────
MIN_ICP_SCORE=7
MAX_EMAILS_PER_DAY=20
YOUR_AGENCY_NAME=PashtX
YOUR_NAME=Syed Anwar
YOUR_EMAIL=
YOUR_CALENDLY=https://calendly.com/yourname/30min
